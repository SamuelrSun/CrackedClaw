# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# App URL (used for OAuth callbacks)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===================
# OAuth Integrations
# ===================

# Google OAuth
# Create at: https://console.cloud.google.com/apis/credentials
# Scopes: Gmail, Calendar, Drive (readonly)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Slack OAuth
# Create at: https://api.slack.com/apps
# Scopes: channels:read, chat:write, users:read, users:read.email
SLACK_CLIENT_ID=your-slack-client-id
SLACK_CLIENT_SECRET=your-slack-client-secret

# Notion OAuth
# Create at: https://www.notion.so/my-integrations
# Type: Public integration
NOTION_CLIENT_ID=your-notion-client-id
NOTION_CLIENT_SECRET=your-notion-client-secret
PROVISIONING_API_SECRET=your_provisioning_api_secret

# Stripe
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_POWER_PRICE_ID=price_...
STRIPE_ULTRA_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...
