{
  "name": "dopl-connect",
  "version": "1.0.0",
  "description": "Dopl Connect — link your machine to your Dopl cloud AI instance",
  "main": "main/index.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.dopl.connect",
    "productName": "Dopl Connect",
    "mac": {
      "target": "dmg",
      "category": "public.app-category.utilities",
      "identity": null,
      "forceCodeSigning": false
    },
    "afterPack": "./scripts/sign.js",
    "dmg": {
      "title": "Dopl Connect",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "files": [
      "main/**/*",
      "renderer/**/*"
    ]
  }
}
